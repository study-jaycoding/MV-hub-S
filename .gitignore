# 백엔드 — 데이터는 data/ 한 폴더로 분리(db·media·shared)
backend/data/
backend/data_backup_*/
# 구버전 경로(재시작 시 data/ 로 자동 이전되지만, 이전 전 보호용으로 유지)
backend/content_hub.db
backend/content_hub.db-wal
backend/content_hub.db-shm
backend/media/
# 백필 스크래치·로그·샘플(영구 자료 아님)
backend/_bf_*
backend/*.log
backend/sample_real.json
# 의존성 설치 마커(런처가 requirements.txt 해시 기록 — 머신 로컬 상태)
backend/.deps_installed
__pycache__/
*.pyc
.venv/

# 프론트엔드
frontend/node_modules/
frontend/dist/
frontend/*.tsbuildinfo

# 릴리즈 산출물
release/packages/
release/_staging/
release/*.zip

# 테스트 소스 지정값(머신마다 다른 로컬 상태 — refresh 배치가 매 실행 시 다시 씀)
# .example 만 추적하고 실제 파일은 각자 로컬에서 생성한다.
pm_test_source_data.txt

# 로컬 테스트 실행이 만드는 임시 폴더(비면 껍데기만 남는다 — 추적 안 함)
/_pm_test_data/
.tmp-*-test-data/
